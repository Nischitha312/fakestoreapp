{"ast":null,"code":"import{useState,useEffect}from'react';import{api}from'../utils/api';export function useProducts(){const[products,setProducts]=useState([]);const[loading,setLoading]=useState(true);const[error,setError]=useState(null);useEffect(()=>{setLoading(true);api.getProducts().then(data=>{setProducts(data);setLoading(false);}).catch(err=>{setError(err.message);setLoading(false);});},[]);return{products,loading,error};}export function useProduct(id){const[product,setProduct]=useState(null);const[loading,setLoading]=useState(true);const[error,setError]=useState(null);useEffect(()=>{if(!id)return;setLoading(true);api.getProduct(id).then(data=>{setProduct(data);setLoading(false);}).catch(err=>{setError(err.message);setLoading(false);});},[id]);return{product,loading,error};}export function useCategories(){const[categories,setCategories]=useState([]);const[loading,setLoading]=useState(true);useEffect(()=>{api.getCategories().then(data=>{setCategories(['all',...data]);setLoading(false);}).catch(()=>setLoading(false));},[]);return{categories,loading};}export function useProductsByCategory(category){const[products,setProducts]=useState([]);const[loading,setLoading]=useState(true);const[error,setError]=useState(null);useEffect(()=>{setLoading(true);const promise=category==='all'?api.getProducts():api.getByCategory(category);promise.then(data=>{setProducts(data);setLoading(false);}).catch(err=>{setError(err.message);setLoading(false);});},[category]);return{products,loading,error};}","map":{"version":3,"names":["useState","useEffect","api","useProducts","products","setProducts","loading","setLoading","error","setError","getProducts","then","data","catch","err","message","useProduct","id","product","setProduct","getProduct","useCategories","categories","setCategories","getCategories","useProductsByCategory","category","promise","getByCategory"],"sources":["D:/nischu/Intern projects/api/fakestore-app/src/hooks/useProducts.js"],"sourcesContent":["import { useState, useEffect } from 'react';\r\nimport { api } from '../utils/api';\r\n\r\nexport function useProducts() {\r\n  const [products, setProducts] = useState([]);\r\n  const [loading,  setLoading]  = useState(true);\r\n  const [error,    setError]    = useState(null);\r\n\r\n  useEffect(() => {\r\n    setLoading(true);\r\n    api.getProducts()\r\n      .then(data => { setProducts(data); setLoading(false); })\r\n      .catch(err  => { setError(err.message); setLoading(false); });\r\n  }, []);\r\n\r\n  return { products, loading, error };\r\n}\r\n\r\nexport function useProduct(id) {\r\n  const [product, setProduct] = useState(null);\r\n  const [loading, setLoading] = useState(true);\r\n  const [error,   setError]   = useState(null);\r\n\r\n  useEffect(() => {\r\n    if (!id) return;\r\n    setLoading(true);\r\n    api.getProduct(id)\r\n      .then(data => { setProduct(data); setLoading(false); })\r\n      .catch(err  => { setError(err.message); setLoading(false); });\r\n  }, [id]);\r\n\r\n  return { product, loading, error };\r\n}\r\n\r\nexport function useCategories() {\r\n  const [categories, setCategories] = useState([]);\r\n  const [loading,    setLoading]    = useState(true);\r\n\r\n  useEffect(() => {\r\n    api.getCategories()\r\n      .then(data => { setCategories(['all', ...data]); setLoading(false); })\r\n      .catch(() => setLoading(false));\r\n  }, []);\r\n\r\n  return { categories, loading };\r\n}\r\n\r\nexport function useProductsByCategory(category) {\r\n  const [products, setProducts] = useState([]);\r\n  const [loading,  setLoading]  = useState(true);\r\n  const [error,    setError]    = useState(null);\r\n\r\n  useEffect(() => {\r\n    setLoading(true);\r\n    const promise = category === 'all' ? api.getProducts() : api.getByCategory(category);\r\n    promise\r\n      .then(data => { setProducts(data); setLoading(false); })\r\n      .catch(err  => { setError(err.message); setLoading(false); });\r\n  }, [category]);\r\n\r\n  return { products, loading, error };\r\n}"],"mappings":"AAAA,OAASA,QAAQ,CAAEC,SAAS,KAAQ,OAAO,CAC3C,OAASC,GAAG,KAAQ,cAAc,CAElC,MAAO,SAAS,CAAAC,WAAWA,CAAA,CAAG,CAC5B,KAAM,CAACC,QAAQ,CAAEC,WAAW,CAAC,CAAGL,QAAQ,CAAC,EAAE,CAAC,CAC5C,KAAM,CAACM,OAAO,CAAGC,UAAU,CAAC,CAAIP,QAAQ,CAAC,IAAI,CAAC,CAC9C,KAAM,CAACQ,KAAK,CAAKC,QAAQ,CAAC,CAAMT,QAAQ,CAAC,IAAI,CAAC,CAE9CC,SAAS,CAAC,IAAM,CACdM,UAAU,CAAC,IAAI,CAAC,CAChBL,GAAG,CAACQ,WAAW,CAAC,CAAC,CACdC,IAAI,CAACC,IAAI,EAAI,CAAEP,WAAW,CAACO,IAAI,CAAC,CAAEL,UAAU,CAAC,KAAK,CAAC,CAAE,CAAC,CAAC,CACvDM,KAAK,CAACC,GAAG,EAAK,CAAEL,QAAQ,CAACK,GAAG,CAACC,OAAO,CAAC,CAAER,UAAU,CAAC,KAAK,CAAC,CAAE,CAAC,CAAC,CACjE,CAAC,CAAE,EAAE,CAAC,CAEN,MAAO,CAAEH,QAAQ,CAAEE,OAAO,CAAEE,KAAM,CAAC,CACrC,CAEA,MAAO,SAAS,CAAAQ,UAAUA,CAACC,EAAE,CAAE,CAC7B,KAAM,CAACC,OAAO,CAAEC,UAAU,CAAC,CAAGnB,QAAQ,CAAC,IAAI,CAAC,CAC5C,KAAM,CAACM,OAAO,CAAEC,UAAU,CAAC,CAAGP,QAAQ,CAAC,IAAI,CAAC,CAC5C,KAAM,CAACQ,KAAK,CAAIC,QAAQ,CAAC,CAAKT,QAAQ,CAAC,IAAI,CAAC,CAE5CC,SAAS,CAAC,IAAM,CACd,GAAI,CAACgB,EAAE,CAAE,OACTV,UAAU,CAAC,IAAI,CAAC,CAChBL,GAAG,CAACkB,UAAU,CAACH,EAAE,CAAC,CACfN,IAAI,CAACC,IAAI,EAAI,CAAEO,UAAU,CAACP,IAAI,CAAC,CAAEL,UAAU,CAAC,KAAK,CAAC,CAAE,CAAC,CAAC,CACtDM,KAAK,CAACC,GAAG,EAAK,CAAEL,QAAQ,CAACK,GAAG,CAACC,OAAO,CAAC,CAAER,UAAU,CAAC,KAAK,CAAC,CAAE,CAAC,CAAC,CACjE,CAAC,CAAE,CAACU,EAAE,CAAC,CAAC,CAER,MAAO,CAAEC,OAAO,CAAEZ,OAAO,CAAEE,KAAM,CAAC,CACpC,CAEA,MAAO,SAAS,CAAAa,aAAaA,CAAA,CAAG,CAC9B,KAAM,CAACC,UAAU,CAAEC,aAAa,CAAC,CAAGvB,QAAQ,CAAC,EAAE,CAAC,CAChD,KAAM,CAACM,OAAO,CAAKC,UAAU,CAAC,CAAMP,QAAQ,CAAC,IAAI,CAAC,CAElDC,SAAS,CAAC,IAAM,CACdC,GAAG,CAACsB,aAAa,CAAC,CAAC,CAChBb,IAAI,CAACC,IAAI,EAAI,CAAEW,aAAa,CAAC,CAAC,KAAK,CAAE,GAAGX,IAAI,CAAC,CAAC,CAAEL,UAAU,CAAC,KAAK,CAAC,CAAE,CAAC,CAAC,CACrEM,KAAK,CAAC,IAAMN,UAAU,CAAC,KAAK,CAAC,CAAC,CACnC,CAAC,CAAE,EAAE,CAAC,CAEN,MAAO,CAAEe,UAAU,CAAEhB,OAAQ,CAAC,CAChC,CAEA,MAAO,SAAS,CAAAmB,qBAAqBA,CAACC,QAAQ,CAAE,CAC9C,KAAM,CAACtB,QAAQ,CAAEC,WAAW,CAAC,CAAGL,QAAQ,CAAC,EAAE,CAAC,CAC5C,KAAM,CAACM,OAAO,CAAGC,UAAU,CAAC,CAAIP,QAAQ,CAAC,IAAI,CAAC,CAC9C,KAAM,CAACQ,KAAK,CAAKC,QAAQ,CAAC,CAAMT,Q